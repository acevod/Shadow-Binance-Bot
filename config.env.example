# Shadow Binance Bot - Configuration
# Copy this file to config.env and fill in your API keys

# Your Binance API Key (read-only recommended)
BINANCE_API_KEY=your_api_key_here

# Your Binance API Secret
BINANCE_API_SECRET=your_api_secret_here

# Optional: Comma-separated list of Spot symbols to analyze (default: BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,SHIBUSDT)
SPOT_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,SHIBUSDT

# Security: Restrict this key to your IP address in Binance API Settings.
